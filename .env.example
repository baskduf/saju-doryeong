# Prisma가 사용하는 DB URL.
# Vercel Postgres를 쓰면 POSTGRES_PRISMA_URL 값을 그대로 넣어주세요.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Vercel Postgres 연결 시 자동 주입되는 값(로컬 테스트 시 선택)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

NEXT_PUBLIC_APP_URL="http://127.0.0.1:3000"
KAKAO_CHANNEL_URL=""
KAKAO_BIZ_FORM_URL=""

# OpenAI fortune narration
OPENAI_API_KEY=""
OPENAI_FORTUNE_MODEL="gpt-4.1-mini"
