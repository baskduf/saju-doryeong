# Primary database connection used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# Optional Vercel Postgres fallback.
# If DATABASE_URL is empty and POSTGRES_PRISMA_URL is set,
# the app will copy this value into DATABASE_URL at runtime.
POSTGRES_PRISMA_URL=""

# Public app base URL used in Kakao cards and page links.
NEXT_PUBLIC_APP_URL="http://127.0.0.1:3000"

# Public Kakao JavaScript key used for the mobile home CTA bridge.
NEXT_PUBLIC_KAKAO_JS_KEY=""

# Public Kakao Channel ID used for channel chat/follow and pf.kakao fallback links.
NEXT_PUBLIC_KAKAO_CHANNEL_PUBLIC_ID="_IjiZX"

# HMAC secret for register/fortune/share access tokens.
APP_SIGNING_SECRET=""

# Shared secret required by /api/kakao?key=...
KAKAO_SKILL_SHARED_SECRET=""

# Optional OpenAI settings.
OPENAI_API_KEY=""
OPENAI_FORTUNE_MODEL="gpt-4.1-mini"
OPENAI_QUESTION_MODEL="gpt-4.1-mini"
