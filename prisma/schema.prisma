generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SajuProfile {
  id                       String                @id @default(cuid())
  userId                   String                @unique
  name                     String?
  birthDate                DateTime
  birthTime                String?
  calendarType             String                @default("solar")
  sajuData                 Json
  questionUsageDateKey     String?
  questionUsageCount       Int                   @default(0)
  shareRewardDateKey       String?
  shareRewardCount         Int                   @default(0)
  pendingQuestionInput     Boolean               @default(false)
  pendingQuestionExpiresAt DateTime?
  shareSnapshots           FortuneShareSnapshot[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
}

model FortuneShareSnapshot {
  id            String   @id @default(cuid())
  userId        String
  targetDateKey String
  payload       Json
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  profile       SajuProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, targetDateKey])
}

model AdminEventLog {
  id           String   @id @default(cuid())
  eventType    String
  status       String
  userId       String?
  source       String
  message      String
  questionText String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([status])
  @@index([userId])
}
